  "title": "Network Bandwidth",
  "uid": "network-bandwidth",
  "description": "Bandwidth attribution — per-component, per-user, hotspot vs local (#403)",
  "tags": ["network", "bandwidth", "metered"],
  "timezone": "browser",
  "refresh": "30s",
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "DS_INFLUXDB",
        "options": [],
        "query": "influxdb",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Totals",
      "id": 100,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Hotspot Bytes (total)",
      "id": 1,
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 104857600 },
              { "color": "red", "value": 524288000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"signalk\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"bandwidth\")\n  |> filter(fn: (r) => r[\"network\"] == \"hotspot\")\n  |> filter(fn: (r) => r[\"_field\"] == \"bytes\")\n  |> sum()",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Local Bytes (total)",
      "id": 2,
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 5 },
