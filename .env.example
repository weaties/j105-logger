CAN_INTERFACE=can0
CAN_BITRATE=250000
DB_PATH=data/logger.db
LOG_LEVEL=INFO
DATA_SOURCE=signalk
SK_HOST=localhost
SK_PORT=3000
# Audio recording (Gordik 2T1R or any USB Audio Class device)
# AUDIO_DEVICE=Gordik
AUDIO_DIR=data/audio
AUDIO_SAMPLE_RATE=48000
AUDIO_CHANNELS=1
# Audio transcription
WHISPER_MODEL=base
# Speaker diarisation — requires free HF account + accepted model terms
# See: huggingface.co/pyannote/speaker-diarization-3.1
# HF_TOKEN=hf_...
# Photo notes
NOTES_DIR=data/notes
# Crew avatars (#100)
AVATAR_DIR=data/avatars
# Transcript trigger keywords (#99) — JSON array of rules
# TRANSCRIPT_TRIGGERS='[{"keyword":"protest","tag":"protest","note_name":"Protest","case_insensitive":true}]'
# SMTP email (optional — welcome emails + new-device alerts)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=j105@example.com
# Authentication (magic-link invite tokens)
# AUTH_DISABLED=true          # bypass auth entirely — local/LAN dev only
# How long session cookies stay valid (days)
AUTH_SESSION_TTL_DAYS=90
# ADMIN_EMAIL=you@example.com # if set, a user with this email is auto-created as admin on startup
# Create users without email flow: j105-logger add-user --email x --name y --role admin
# Timezone — controls weekday event naming and UI timestamp display (default: UTC)
# TIMEZONE=America/Los_Angeles
# Web interface (race marker)
WEB_HOST=0.0.0.0
WEB_PORT=3002
# WEB_PIN=
# Grafana dashboard links (JS uses the same hostname the user is browsing on)
GRAFANA_PORT=3001
GRAFANA_DASHBOARD_UID=j105-sailing
# InfluxDB — required only for system health metrics; omit if not using InfluxDB
# INFLUX_URL=http://localhost:8086
# INFLUX_TOKEN=
# INFLUX_ORG=j105
# INFLUX_BUCKET=signalk
