CAN_INTERFACE=can0
CAN_BITRATE=250000
DB_PATH=data/logger.db
LOG_LEVEL=INFO
DATA_SOURCE=signalk
SK_HOST=localhost
SK_PORT=3000
# Audio recording (Gordik 2T1R or any USB Audio Class device)
# AUDIO_DEVICE=Gordik
AUDIO_DIR=data/audio
AUDIO_SAMPLE_RATE=48000
AUDIO_CHANNELS=1
# Audio transcription
WHISPER_MODEL=base
# Speaker diarisation — requires free HF account + accepted model terms
# See: huggingface.co/pyannote/speaker-diarization-3.1
# HF_TOKEN=hf_...
# Remote transcription worker (optional — offload to a faster machine over Tailscale)
# TRANSCRIBE_URL=http://macbook:8321
# Photo notes
NOTES_DIR=data/notes
# Crew avatars (#100)
AVATAR_DIR=data/avatars
# Transcript trigger keywords (#99) — JSON array of rules
# TRANSCRIPT_TRIGGERS='[{"keyword":"protest","tag":"protest","note_name":"Protest","case_insensitive":true}]'
# SMTP email (optional — welcome emails + new-device alerts)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=helmlog@example.com
# Authentication (#268 — invitation + flexible auth)
# AUTH_DISABLED=true          # bypass auth entirely — local/LAN dev only
# SESSION_SECRET=             # secret key for session cookie signing (OAuth state); auto-generated if unset
# How long session cookies stay valid (days)
AUTH_SESSION_TTL_DAYS=90
# OAuth providers (optional — only providers with configured vars are enabled)
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_APPLE_CLIENT_ID=
# OAUTH_APPLE_PRIVATE_KEY_PATH=
# OAUTH_APPLE_KEY_ID=
# OAUTH_APPLE_TEAM_ID=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# ADMIN_EMAIL=you@example.com # if set, a user with this email is auto-created as admin on startup
# Create users without email flow: helmlog add-user --email x --name y --role admin
# Timezone — controls weekday event naming and UI timestamp display (default: UTC)
# TIMEZONE=America/Los_Angeles
# External data fetching — sends reduced-precision GPS to Open-Meteo/NOAA (#209)
# EXTERNAL_DATA_ENABLED=true   # set to false to disable weather/tide fetching
# Camera control (Insta360 X4 via WiFi, Open Spherical Camera API)
# CAMERAS=main:192.168.42.1
CAMERA_START_TIMEOUT=10
# YouTube auto-association (match uploads to camera sessions)
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxx
# Video pipeline (Mac-side — stitching + YouTube upload)
# VIDEO_OUTPUT_DIR=~/Videos/helmlog
# VIDEO_RESOLUTION=3840x1920
# YOUTUBE_CLIENT_SECRETS=~/.helmlog-youtube-client-secrets.json
# YOUTUBE_TOKEN_FILE=~/.helmlog-youtube-token.json
# PI_API_URL=http://corvopi:3002
# VIDEO_PRIVACY=private
# VIDEO_CLEANUP_AFTER_UPLOAD=false  # delete stitched MP4 after YouTube upload
# PI_SESSION_COOKIE=              # session cookie from Pi — enables auto-linking videos to sessions
# Web interface (race marker)
WEB_HOST=0.0.0.0
WEB_PORT=3002
# WEB_PIN=
# Grafana dashboard links (JS uses the same hostname the user is browsing on)
GRAFANA_PORT=3001
GRAFANA_DASHBOARD_UID=helmlog-sailing
# Deployment management (#125)
# DEPLOY_MODE=explicit            # explicit (manual) or evergreen (auto-deploy).
# DEPLOY_BRANCH=main              # branch to track for updates
# DEPLOY_POLL_INTERVAL=300        # seconds between update checks
# DEPLOY_WINDOW_START=            # UTC hour to begin auto-deploys (evergreen only)
# DEPLOY_WINDOW_END=              # UTC hour to end auto-deploys (evergreen only)
# GITHUB_REPO=weaties/helmlog     # owner/repo for changelog API
# GITHUB_TOKEN=                   # GitHub PAT for richer changelog (optional)
# InfluxDB — required only for system health metrics; omit if not using InfluxDB
# INFLUX_URL=http://localhost:8086
# INFLUX_TOKEN=
# INFLUX_ORG=helmlog
# INFLUX_BUCKET=signalk
# Health monitor collection frequency (1–300 seconds; default 2)
MONITOR_INTERVAL_S=2
# Gaia GPS import (#101) — session cookie auth from browser
# GAIGPS_SESSION_ID=
# GAIGPS_CSRF_TOKEN=
# GAIGPS_SINCE=2025-01-01
# GAIGPS_RACE_AREA_LAT=47.688
# GAIGPS_RACE_AREA_LON=-122.417
# GAIGPS_RACE_AREA_RADIUS_NM=5.0
# GAIGPS_CLASSIFIER_CONFIDENCE_THRESHOLD=0.6
